{
  "name": "@hair/backend",
  "version": "1.0.0",
  "description": "HairVision 3D Backend API",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:status": "supabase status",
    "supabase:types": "supabase gen types typescript --local --schema public > src/types/database.types.ts",
    "db:migrate": "supabase db diff --local --schema public | supabase db apply --local",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["hair", "3d", "ai", "beauty", "salon"],
  "author": "HairVision Team",
  "license": "MIT",
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.1",
    "@supabase/supabase-js": "^2.39.8",
    "dotenv": "^17.2.4",
    "hono": "^4.11.7",
    "zod": "^4.3.6",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.1",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "supabase": "^1.200.3"
  }
}