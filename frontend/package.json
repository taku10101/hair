    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
