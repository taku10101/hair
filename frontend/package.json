{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "mock:generate": "tsx src/mock/generate-db.ts",
    "mock:server": "json-server src/mock/data/db.json --port 3088",
    "mock:dev": "pnpm mock:generate && pnpm mock:server"
  },
  "dependencies": {
